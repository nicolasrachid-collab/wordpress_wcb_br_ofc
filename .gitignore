# =============================================
# WordPress .gitignore — White Cloud Brasil
# =============================================

# Configurações sensíveis
wp-config.php
wp-config-local.php
.env
.env.*

# Core WordPress (opcional: mantenha se quiser versionar o core)
# /wp-admin/
# /wp-includes/

# Uploads (imagens/mídia — pesado, use CDN/backup separado)
wp-content/uploads/

# Caches de plugins
wp-content/cache/
wp-content/w3tc-config/
wp-content/wflogs/

# Logs
*.log
debug.log
logs/

# Arquivos de compilação / build
node_modules/
wp-content/themes/wcb-theme/vendor/
wp-content/themes/wcb-theme/.phpunit.cache/
.sass-cache/
.cache/

# Arquivos do sistema
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# IDE
.cursor/
.vscode/
.idea/
*.code-workspace
*.sublime-project
*.sublime-workspace

# PHP
*.phar

# Backups (WPvivid — ficheiros grandes; não versionar)
wp-content/wpvividbackups/

# Backups
*.bak
*.backup
*.old
*.bk

# Zip temporários
*.zip
*.tar.gz
*.tar

# WooCommerce logs
wp-content/plugins/woocommerce/logs/

# Arquivos temporários do XAMPP
xampp/

# Local / ferramentas / saídas de debug (não versionar)
.sfdx/
products-output.txt
wp-content/litespeed/
wp-content/plugins/litespeed-cache/

# Dumps de servidor / migração (podem conter wp-config e credenciais)
server_*.json
wpconfig_*.json
